<UserControl x:Class="ZipGameImporter.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ZipGameImporter" >
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>


        <!-- ZIP folder -->
        <TextBlock Text="ZIP source folder"
                   Grid.Row="0"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Margin="5"/>

        <TextBox Text="{Binding IncomingFolder}"
                 Grid.Row="0"
                 Grid.Column="1"
                 Margin="5"
                 VerticalAlignment="Center"/>

        <Button Content="Browse"
                Grid.Row="0"
                Grid.Column="2"
                Margin="5"
                Command="{Binding BrowseIncomingCommand}"/>


        <!-- Games folder -->
        <TextBlock Text="Games installation folder"
                   Grid.Row="1"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Margin="5"/>

        <TextBox Text="{Binding GamesFolder }"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="5"
                 VerticalAlignment="Center"/>

        <Button Content="Browse"
                Grid.Row="1"
                Grid.Column="2"
                Margin="5"
                Command="{Binding BrowseGamesCommand}"/>


        <!-- Source -->
        <TextBlock Text="Source"
                   Grid.Row="2"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Margin="5"/>

        <ComboBox ItemsSource="{Binding Sources}"
                  SelectedValue="{Binding SourceId, Mode=TwoWay}"
                  SelectedValuePath="Id"
                  DisplayMemberPath="Name"
                  Grid.Row="2"
                  Grid.Column="1"
                  Margin="5"/>


        <!-- Categories -->
        <TextBlock Text="Categories"
                   Grid.Row="3"
                   Grid.Column="0"
                   VerticalAlignment="Top"
                   Margin="5"/>

        <ComboBox x:Name="CategoriesComboBox"
          ItemsSource="{Binding Categories}"
          Grid.Row="3"
          Grid.Column="1"
          Margin="5"
          Text="{Binding SelectedCategoriesText, Mode=OneWay}"
          IsEditable="True"
          IsReadOnly="True"
          StaysOpenOnEdit="True">

            <ComboBox.Resources>
                <Style TargetType="TextBox">
                    <Setter Property="IsHitTestVisible" Value="False"/>
                </Style>

                <Style TargetType="ComboBoxItem">
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </ComboBox.Resources>

            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}"
                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                      Checked="CategoryCheckedChanged"
                      Unchecked="CategoryCheckedChanged"
                      HorizontalAlignment="Stretch"
                              Padding="6,4"
                      VerticalAlignment="Stretch"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>

        </ComboBox>

        <!-- Hidden -->
        <CheckBox Content="Hidden"
                  IsChecked="{Binding Hidden, Mode=TwoWay}"
                  Grid.Row="4"
                  Grid.Column="1"
                  Margin="5"/>

        <Button Content="Remove" Grid.Row="4" Grid.Column="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="5"
            Command="{Binding RemoveCommand}" />

    </Grid>
</UserControl>
